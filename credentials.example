# 憑證範本 — 複製到 ~/.ai_news_hub/credentials 並 chmod 600
# 此檔案僅為「範本」，請勿在任何 git 追蹤檔案填入真實金鑰。
#
#   mkdir -p ~/.ai_news_hub
#   cp credentials.example ~/.ai_news_hub/credentials
#   chmod 600 ~/.ai_news_hub/credentials
#
# 各平台申請步驟詳見 docs/social_setup.md

# Claude API（翻譯用）— https://platform.claude.com
ANTHROPIC_API_KEY=

# Facebook 粉絲專頁（Meta Graph API）
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram 商業帳號（Instagram Graph API，需連結 FB 粉專）
INSTAGRAM_IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Threads（Threads API）
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# YouTube（YouTube Data API v3，OAuth2）
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# 自訂平台範例（平台憑證前綴_TOKEN）
# MYBLOG_TOKEN=

# NotebookLM （NotebookLM API）
# NOTEBOOKLM_NOTEBOOK_ID=