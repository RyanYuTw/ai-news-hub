# 憑證範本 — 複製到 ~/.ai_news_hub/credentials 並 chmod 600
# 此檔案僅為「範本」，請勿在任何 git 追蹤檔案填入真實金鑰。
#
#   mkdir -p ~/.ai_news_hub
#   cp credentials.example ~/.ai_news_hub/credentials
#   chmod 600 ~/.ai_news_hub/credentials

# ── Flask（建議填入）───────────────────────────────────────────────────────
# 用於簽署 session cookie；不填則每次重啟自動產生隨機值（session 會失效）
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# ── NotebookLM（必填）──────────────────────────────────────────────────────
# notebooklm.google.com 建立一個 notebook，複製其 UUID
NOTEBOOKLM_NOTEBOOK_ID=

# ── Google Drive（選填）────────────────────────────────────────────────────
# OAuth2 設定：執行 python setup_gdrive.py 完成一次性授權
# token 自動儲存於 ~/.ai_news_hub/gdrive_token.json
# 在 Drive 建立下列兩個資料夾，填入資料夾 ID
GDRIVE_TXT_FOLDER_ID=      # ai_news_hub/txt  資料夾 ID（翻譯結果 TXT）
GDRIVE_IMAGES_FOLDER_ID=   # ai_news_hub/images 資料夾 ID（生成圖片）

# ── 排程（選填，使用預設可不填）────────────────────────────────────────────
# COLLECT_CRON=0 */2 * * *      # 蒐集頻率（預設每 2 小時整點）
# TRANSLATE_CRON=*/10 * * * *   # 翻譯頻率（預設每 10 分鐘一篇）
